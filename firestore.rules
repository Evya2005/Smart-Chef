rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && request.auth.token.email in ['evya2005@gmail.com'];
    }

    // ── User-scoped data ──────────────────────────────────────────────
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn()
                         && request.auth.uid == userId;
    }

    // ── Public recipes ────────────────────────────────────────────────
    match /public_recipes/{recipeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn()
                             && request.auth.uid == resource.data.userId;
    }

    // ── User profiles (public name/email lookup for shared recipes) ───
    match /user_profiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // ── App configuration (categories, etc.) ─────────────────────────
    // All authenticated users read (CategoryChipBar needs categories).
    // Only admin may write.
    match /app_config/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Admin: cross-user recipe reads (God Mode) ─────────────────────
    match /{path=**}/recipes/{recipeId} {
      allow read: if isAdmin();
    }

    // ── Default deny ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
